# ─────────────────────────────────────────────────────────
# PRISM: Environment Configuration
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── User identity ────────────────────────────────────────
# Your name (used by autopilot display and roleplaying)
USER_NAME=User

# ── HuggingFace ───────────────────────────────────────────
# Required to download gated models
HF_TOKEN=your_huggingface_token_here

# ── Model identity ────────────────────────────────────────
MODEL_ID=Qwen/Qwen2.5-14B-Instruct
MODEL_LOCAL_PATH=./model/weights/qwen2.5-14b-instruct

# ── Adapter paths ─────────────────────────────────────────
ADAPTER_PATH=./adapters/current
TITANS_ADAPTER_PATH=./adapters/titans

# ── Experience database (SQLite path) ────────────────────
EXPERIENCE_DB_URL=sqlite+aiosqlite:///./data/experience.db

# ── Weights & Biases (optional, leave empty to disable) ──
WANDB_API_KEY=
WANDB_PROJECT=prism

# ── Server ────────────────────────────────────────────────
SERVER_PORT=8000

# ── Hardware ──────────────────────────────────────────────
DEVICE=cuda
QUANTIZATION=4bit

# ── LoRA hyperparameters ──────────────────────────────────
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# ── Titans adapter ────────────────────────────────────────
TITANS_MEMORY_DIM=512
TITANS_MEMORY_LAYERS=0
TITANS_GATING_METHOD=MaG
# Size of the persistent memory bank (number of memory slots)
TITANS_MEMORY_SIZE=512
# Momentum for memory update rule
TITANS_MOMENTUM=0.9

# ── Training thresholds ───────────────────────────────────
TRAINING_MIN_FITNESS=0.6
TRAINING_MIN_EPISODES=50
TRAINING_CRON=0 3 * * *

# ── Training hyperparameters ──────────────────────────────
MAX_SEQ_LENGTH=4096
BATCH_SIZE=2
GRAD_ACCUM_STEPS=4
LEARNING_RATE=2e-4
WARMUP_RATIO=0.03
NUM_EPOCHS=1

# ── Anthropic API (Dream Consolidation + Contradiction Engine) ──
# Get your key at: console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Dream Consolidation ───────────────────────────────────
CONSOLIDATION_MIN_FITNESS=0.6
CONSOLIDATION_MIN_CLUSTER_SIZE=3
CONSOLIDATION_SIMILARITY_THRESHOLD=0.75
CONSOLIDATION_MIN_CONFIDENCE=0.80

# ── Contradiction Engine ──────────────────────────────────
CONTRADICTION_SIMILARITY_THRESHOLD=0.80
CONTRADICTION_MIN_CONFIDENCE=0.75

# ── Semantic memory validation ────────────────────────────
SEMANTIC_VALIDATION_THRESHOLD=3
SEMANTIC_PRUNE_DAYS=14

# ── MIRROR Protocol ───────────────────────────────────────
# MIRROR uses an Oracle LLM (Claude) to auto-score episodes
# until PRISM's own scores converge with the Oracle's.
# Once converged, scoring is handled internally.
MIRROR_ENABLED=true
# Oracle model used for MIRROR scoring
MIRROR_ORACLE_MODEL=claude-sonnet-4-6
# Override API key for MIRROR (falls back to ANTHROPIC_API_KEY if blank)
MIRROR_ANTHROPIC_API_KEY=
# Path to the MIRROR context file (describes user identity/goals)
MIRROR_CONTEXT_FILE=./data/mirror_context.md
# Delta threshold below which MIRROR is considered converged
MIRROR_CONVERGENCE_THRESHOLD=0.30
# Rolling window size (number of episodes) for convergence tracking
MIRROR_CONVERGENCE_WINDOW=50
# Set to true once MIRROR has converged (disables Oracle calls)
MIRROR_CONVERGED=false

# ── Cortex Loop (layer duplication for reasoning depth) ───
# Inspired by the RYS (Repeat Your Self) technique
CORTEX_LOOP_ENABLED=false
# Path to the Cortex Loop enhanced model weights
CORTEX_LOOP_MODEL_PATH=./model_rys
# Path to the best Cortex Loop configuration JSON
CORTEX_LOOP_CONFIG_PATH=./config/rys_config.json
# Path to the Cortex Loop seam targeting config JSON
CORTEX_LOOP_SEAM_PATH=./config/rys_seam.json
# Set to true once the Cortex Loop scan is complete
CORTEX_LOOP_SCAN_COMPLETE=false

# ── Spaced Repetition (Fibonacci-interval replay of trained episodes) ──
SPACED_REPLAY_ENABLED=true
SPACED_REPLAY_MAX_PER_BATCH=50

# ── Active Recall (test model retention, re-queue forgotten episodes) ──
ACTIVE_RECALL_ENABLED=true
ACTIVE_RECALL_THRESHOLD=0.40
ACTIVE_RECALL_SAMPLE_SIZE=30

# ── TMR Dream Consolidation (prioritize high-delta salient memories) ──
TMR_ENABLED=true
TMR_SALIENT_DELTA_THRESHOLD=1.5
TMR_REACTIVATION_RATIO=0.20

# ── Interleaved Training (round-robin topic ordering) ─────
INTERLEAVE_ENABLED=true

# ── Mixed Knowledge (general Q&A to prevent catastrophic forgetting) ──
# Dataset split: ~60% episodic, 30% general knowledge, 10% spaced replay
MIXED_KNOWLEDGE_ENABLED=true
MIXED_KNOWLEDGE_RATIO=0.30
SPACED_REPLAY_RATIO=0.10
MIXED_KNOWLEDGE_PATH=./data/general

# ── Frustration Detection (regex-based, zero API cost) ───
FRUSTRATION_DETECTION_ENABLED=true

# ── Idle-time Dream Consolidation ────────────────────────
IDLE_CONSOLIDATION_ENABLED=true
# Minutes of inactivity before triggering consolidation
IDLE_CONSOLIDATION_MINUTES=30
# Minimum minutes between idle consolidation runs
IDLE_CONSOLIDATION_COOLDOWN_MINUTES=120

# ── Memory Validation and Injection ──────────────────────
MEMORY_INJECTION_ENABLED=true
MEMORY_VALIDATION_MIN_SOURCE_FITNESS=0.5
MEMORY_VALIDATION_MAX_STALENESS_DAYS=30
MEMORY_VALIDATION_MIN_CONFIDENCE=0.50

# ── Instincts System (learned behavioral rules) ─────────
INSTINCTS_ENABLED=true
INSTINCTS_MAX_ACTIVE=20
INSTINCTS_MIN_CONFIDENCE=0.60

# ── Context Compaction (session history summarization) ───
COMPACTION_ENABLED=true
# Approximate token threshold before compaction triggers
COMPACTION_TOKEN_THRESHOLD=3000
# Number of recent turns to keep uncompacted
COMPACTION_KEEP_RECENT=6
